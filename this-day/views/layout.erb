<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= locals[:date_string] ? "This Day in Viet Nam — #{locals[:date_string]}" : "This Day in Viet Nam" %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, "Times New Roman", serif;
      line-height: 1.6;
      color: #2c2c2c;
      background-color: #faf8f5;
      padding: 2rem 1rem;
    }

    main {
      max-width: 42rem;
      margin: 0 auto;
    }

    .day-nav {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      font-size: 0.9rem;
    }

    .day-nav a {
      color: #8b7355;
      text-decoration: none;
      padding: 0.25rem 0;
    }

    .day-nav a:hover {
      text-decoration: underline;
    }

    h1 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      color: #3a3a3a;
      border-bottom: 2px solid #8b7355;
      padding-bottom: 0.5rem;
    }

    .event-body {
      margin-bottom: 1.5rem;
    }

    .event-body p {
      margin-bottom: 1rem;
    }

    .event-photo {
      float: right;
      max-width: 280px;
      margin: 0 0 1rem 1.5rem;
    }

    .event-photo img {
      width: 100%;
      height: auto;
      display: block;
    }

    .event-photo figcaption {
      font-size: 0.85rem;
      color: #666;
      margin-top: 0.25rem;
    }

    .references {
      clear: both;
      border-top: 1px solid #ccc;
      padding-top: 1rem;
      margin-top: 1.5rem;
    }

    .references h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
      color: #555;
    }

    .references ol {
      padding-left: 1.25rem;
    }

    .references li {
      margin-bottom: 0.25rem;
    }

    .references a {
      color: #4a6fa5;
      text-decoration: none;
    }

    .references a:hover {
      text-decoration: underline;
    }

    .fallback {
      text-align: center;
      padding: 3rem 1rem;
      color: #666;
    }

    .fallback p {
      font-size: 1.1rem;
    }

    @media (max-width: 480px) {
      h1 { font-size: 1.25rem; }

      .event-photo {
        float: none;
        max-width: 100%;
        margin: 0 0 1rem 0;
      }
    }
  </style>
</head>
<body>
  <main>
    <%= yield %>
  </main>
</body>
</html>
